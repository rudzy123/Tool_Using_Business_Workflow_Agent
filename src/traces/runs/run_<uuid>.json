
import json
from pathlib import Path

from src.evals.evaluator import WorkflowEvaluator
from src.evals.reports import format_eval_report

run_file = Path("src/traces/runs").glob("run_*.json")
run_path = next(run_file)

payload = json.loads(run_path.read_text())

evaluator = WorkflowEvaluator()
scores = evaluator.evaluate(payload)

print(format_eval_report(scores))

